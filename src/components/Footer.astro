---
import type { Lang } from "../i18n/translations";
import { translations } from "../i18n/translations";
interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = translations[lang].footer;
const year = new Date().getFullYear();
---

<footer>
  <div class="footer-inner">
    <div class="footer-logo" aria-hidden="true">
      <div class="logo-icon">&lt;/&gt;</div>
      <span class="logo-text">SUNRISE PRODUCTIONS</span>
    </div>
    <p class="footer-copy">
      © {year} <span class="accent">Sunrise Productions</span> — {t.rights}
    </p>
    <div class="footer-links">
      <a href="https://github.com/JdR2V" target="_blank" rel="noopener noreferrer">GitHub</a>
      <a href="https://jdr2v.itch.io" target="_blank" rel="noopener noreferrer">itch.io</a>
      <a href="https://jdr2v.github.io/portfolio" target="_blank" rel="noopener noreferrer">Portfolio</a>
    </div>
  </div>
</footer>

<style>
footer {
  background: var(--black);
  border-top: 1px solid #1a1a1a;
  padding: 2rem 1.5rem;
}
.footer-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 1rem;
}
.footer-logo { display: flex; align-items: center; gap: 8px; }
.logo-icon { width: 26px; height: 26px; background: var(--yellow); border-radius: 3px; display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 900; color: var(--black); }
.logo-text { font-size: 0.65rem; font-weight: 900; letter-spacing: 0.15em; color: #555; }
.footer-copy { font-size: 0.75rem; color: #555; }
.footer-copy .accent { color: var(--yellow); font-weight: 700; }
.footer-links { display: flex; gap: 1rem; }
.footer-links a { font-size: 0.75rem; color: #555; transition: color 0.2s; }
.footer-links a:hover { color: var(--yellow); }
</style>
